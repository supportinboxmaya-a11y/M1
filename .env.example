# Core Maya URL — where M1 connects to health-ping
CORE_MAYA_URL=http://localhost:8000

# M1's own HTTP port
M1_PORT=3001

# Gate — set to true to activate M1
M1_ENABLED=false

# Ping interval in milliseconds (default 30s)
M1_PING_INTERVAL_MS=30000

# --- Dual Brain ---
# Enable M1's own lightweight reasoning layer
# Provider chain: NVIDIA NIM (primary) → Gemini (fallback 1) → Groq (fallback 2) → raw status (no brain)
M1_DUAL_BRAIN_ENABLED=false

# NVIDIA NIM API key — primary brain (free at build.nvidia.com, 80+ open models)
# Can share core Maya's NVIDIA_NIM_KEY since they run on the same device
NVIDIA_NIM_KEY=

# NVIDIA NIM model to use (default: deepseek-ai/deepseek-v3)
M1_NVIDIA_NIM_MODEL=deepseek-ai/deepseek-v4-pro

# M1's own Gemini API key (separate from core Maya's key pool)
# Primary var name; GEMINI_API_KEY is also accepted as fallback
M1_EMERGENCY_GEMINI_KEY=

# Groq API key — fallback LLM for emergency alerts when other providers are unavailable
# (Added after Gemini free-tier quota exhaustion during testing)
M1_EMERGENCY_GROQ_KEY=

# Minimum minutes between LLM calls (cost guard)
M1_GEMINI_COOLDOWN_MIN=15

# Rolling window in minutes for local pattern analysis on /health
M1_ANALYSIS_WINDOW_MIN=5

# Max entries in the rolling health history buffer
M1_HISTORY_MAX_ENTRIES=100
