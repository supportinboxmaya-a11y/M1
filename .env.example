# Core Maya URL — where M1 connects to health-ping
CORE_MAYA_URL=http://localhost:8000

# M1's own HTTP port
M1_PORT=3001

# Gate — set to true to activate M1
M1_ENABLED=false

# Ping interval in milliseconds (default 30s)
M1_PING_INTERVAL_MS=30000

# --- Dual Brain ---
# Enable M1's own lightweight reasoning layer
M1_DUAL_BRAIN_ENABLED=false

# M1's own Gemini API key (separate from core Maya's key pool)
GEMINI_API_KEY=

# Minimum minutes between Gemini calls (cost guard)
M1_GEMINI_COOLDOWN_MIN=15

# Rolling window in minutes for local pattern analysis on /health
M1_ANALYSIS_WINDOW_MIN=5

# Max entries in the rolling health history buffer
M1_HISTORY_MAX_ENTRIES=100
